<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-current.dtd">
<suite name="Salesforce Login Test Suite" parallel="false" thread-count="1">
	<listeners>
		<listener class-name="com.salesforce.listeners.TestListener" />
	</listeners>

	<test name="Valid Login Tests" enabled="true">
		<classes>
			<class name="com.salesforce.tests.LoginTestValid">
				<methods>
					<include name="testLoginPageLoad" />
					<include name="testLoginWithValidCredentials" />
					<include name="testPasswordFieldMasking" />
					<include name="testLoginWithRememberMe" />
					<include name="testForgotPasswordLinkPresence" />
					<include name="testLoginButtonPresence" />
				</methods>
			</class>
		</classes>
	</test>

	<test name="Invalid Login Tests" enabled="true">
		<classes>
			<class name="com.salesforce.tests.LoginTestInvalid">
				<methods>
					<include name="testLoginWithEmptyCredentials" />
					<include name="testLoginWithInvalidPassword" />
					<include name="testLoginWithInvalidEmailFormat" />
					<include name="testLoginWithEmptyPassword" />
					<include name="testLoginWithNonExistentUsername" />
					<include name="testErrorMessageDisplay" />
					<include name="testLoginPageTitleAfterFailedLogin" />
					<include name="testUsernameFieldAfterFailedLogin" />
				</methods>
			</class>
		</classes>
	</test>
</suite>
